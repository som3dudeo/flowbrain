# ─────────────────────────────────────────────────────────────────
# n8n Flow Finder — Environment Configuration
#
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your values below
# 3. Restart the server for changes to take effect
# ─────────────────────────────────────────────────────────────────


# ── n8n Server ───────────────────────────────────────────────────
# The URL where your n8n instance is running
N8N_BASE_URL=http://localhost:5678


# ── FlowBrain Dispatcher Webhook ─────────────────────────────────
# The FlowBrain dispatcher workflow in n8n listens here.
# Create a Webhook node in n8n at path "flowbrain" (POST,
# response mode "When Last Node Finishes") and activate it.
N8N_DEFAULT_WEBHOOK=http://localhost:5678/webhook/flowbrain


# ── Internal server URL ──────────────────────────────────────────
# Used by auto_executor to call back into the FlowBrain server.
# Must match PORT below. Use 127.0.0.1, not localhost, to avoid
# hitting Docker services that may also be bound to localhost.
FLOW_FINDER_URL=http://127.0.0.1:8001


# ── Server Settings ──────────────────────────────────────────────
# Default: 8001 (avoids conflict with Docker services on port 8000)
PORT=8001
