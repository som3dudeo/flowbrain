# ─────────────────────────────────────────────────────────────────
# n8n Flow Finder — Environment Configuration
#
# 1. Copy this file: cp .env.example .env
# 2. Fill in your values below
# 3. Restart the server for changes to take effect
# ─────────────────────────────────────────────────────────────────


# ── n8n Server ───────────────────────────────────────────────────
# The URL where your n8n instance is running
N8N_BASE_URL=http://localhost:5678


# ── Workflow Webhook URLs ────────────────────────────────────────
# Map workflow IDs to their n8n webhook URLs.
# Format:  N8N_WEBHOOK_<workflow_id>=<webhook_url>
#
# To find the webhook URL for a workflow in n8n:
#   1. Open the workflow in your n8n editor
#   2. Add a "Webhook" trigger node
#   3. Activate the workflow
#   4. Copy the "Production URL" from the Webhook node
#
# Examples (replace the IDs and URLs with your own):
# N8N_WEBHOOK_1234=http://localhost:5678/webhook/abc-def-123
# N8N_WEBHOOK_5678=http://localhost:5678/webhook/xyz-uvw-456

# ── Default Webhook (optional) ───────────────────────────────────
# If a workflow doesn't have a specific webhook URL above,
# this fallback URL will be used instead.
# Useful if you have a single dispatcher workflow in n8n.
# N8N_DEFAULT_WEBHOOK=http://localhost:5678/webhook/my-dispatcher


# ── Server Settings ──────────────────────────────────────────────
PORT=8000
