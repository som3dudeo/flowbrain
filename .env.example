# ─────────────────────────────────────────────────────────────────
# FlowBrain — Environment Configuration
#
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your values below
# 3. Restart the server for changes to take effect
# ─────────────────────────────────────────────────────────────────


# ── Server Settings ──────────────────────────────────────────────
# Default: localhost:8001 (safe by default — not exposed to network)
FLOWBRAIN_HOST=127.0.0.1
FLOWBRAIN_PORT=8001

# Legacy aliases (FLOWBRAIN_ vars take precedence)
# PORT=8001
# HOST=127.0.0.1


# ── n8n Connection ───────────────────────────────────────────────
# The URL where your n8n instance is running
N8N_BASE_URL=http://localhost:5678

# The FlowBrain dispatcher workflow webhook in n8n.
# Create a Webhook node in n8n at path "flowbrain" (POST,
# response mode "When Last Node Finishes") and activate it.
N8N_DEFAULT_WEBHOOK=http://localhost:5678/webhook/flowbrain


# ── Internal URL ─────────────────────────────────────────────────
# Used by auto_executor to call back into the FlowBrain server.
# Must match FLOWBRAIN_HOST/PORT above.
FLOWBRAIN_URL=http://127.0.0.1:8001

# Legacy alias still supported:
# FLOW_FINDER_URL=http://127.0.0.1:8001


# ── Safety Thresholds ────────────────────────────────────────────
# Minimum confidence to auto-execute (0.0–1.0). Default: 0.85
# FLOWBRAIN_MIN_AUTOEXEC_CONFIDENCE=0.85

# Minimum confidence to offer a preview. Default: 0.40
# FLOWBRAIN_MIN_PREVIEW_CONFIDENCE=0.40

# Whether to auto-execute by default (true/false). Default: false
# FLOWBRAIN_AUTO_EXECUTE=false


# ── Optional: Local LLM for parameter extraction ────────────────
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2
